# Copy this file to .env.local and fill in the values.
# See references/membership-env-setup.md for step-by-step setup instructions.

# Google Sheets member roster
# The long string in the sheet URL between /d/ and /edit
MEMBERS_SHEET_ID=

# Google Sheets news feed
NEWS_SHEET_ID=

# Service account credentials (Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Optional — defaults to Members!A2:D if not set
# MEMBERS_SHEET_RANGE=Members!A2:D
